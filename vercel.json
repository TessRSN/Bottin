{
  "crons": [
    {
      "path": "/api/export",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/backup-auto",
      "schedule": "0 3 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
